{
  "manifest_version": 3,
  "name": "Property Pipeline Importer",
  "version": "0.2.0",
  "description": "Import listing data from the current page into Property Pipeline.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Property Pipeline"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://property-pipeline-crm.vercel.app/*"
  ]
}
